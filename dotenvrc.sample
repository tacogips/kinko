# direnv sample for kinko
#
# Usage:
# 1) Save as .envrc in your project root (or source it from your existing .envrc).
# 2) Initialize and unlock once for this project-local data dir:
#      kinko --kinko-dir "${PWD}/.direnv/kinko" init
#      kinko --kinko-dir "${PWD}/.direnv/kinko" unlock
# 3) Allow direnv:
#      direnv allow
#
# Secrets are stored encrypted under .direnv/kinko and loaded for this directory scope.

export KINKO_PROFILE=default
KINKO_SCOPE_DIR="${DIRENV_DIR#-}"
export KINKO_DATA_DIR="${KINKO_SCOPE_DIR}/.direnv/kinko"

# kinko direnv export auto-resolves scope from DIRENV_DIR and uses non-interactive-safe mode.
eval "$(kinko direnv export)"
